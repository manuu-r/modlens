{
  "private": true,
  "name": "mod-lens",
  "version": "0.0.0",
  "description": "Reddit-native context for queue decisions: author notes, site tags, mod log search, risk rules, alerts, and one-line insights.",
  "license": "BSD-3-Clause",
  "type": "module",
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "build": "vite build",
    "deploy": "pnpm run type-check && pnpm run lint && pnpm run test && devvit upload",
    "dev": "node scripts/devvit-config.mjs playtest",
    "dev:seed": "MODLENS_ENABLE_DEV_SEED=true node scripts/devvit-config.mjs playtest",
    "launch": "pnpm run deploy && devvit publish",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "test": "vitest run --config vitest.config.ts",
    "type-check": "tsc --build"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/reddit": "0.12.23",
    "@devvit/redis": "^0.12.23",
    "@devvit/shared-types": "0.12.23",
    "@devvit/start": "0.12.23",
    "@devvit/web": "0.12.24",
    "@hono/node-server": "2.0.2",
    "devvit": "0.12.23",
    "hono": "4.12.18"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.2",
    "eslint": "10.3.0",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.11",
    "vitest": "^4.1.6"
  }
}
